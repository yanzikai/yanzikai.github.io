/**index.wxss**/
.swiper-tab{  
    display: flex;
    flex-wrap: nowrap;
    text-align: center;  
    line-height: 68rpx;}  
.swiper-tab-list{  
    font-size: 28rpx;  
    display: inline-block;  
    color: #777777;  
    width:60rpx;
    margin:0 25rpx;
}  
.on{
  color: #000;  
  border-bottom: 6rpx solid #e73933;
}  
.swiper-box{ display: block; height: 100%; width: 100%; overflow: hidden; }  
page{
  height: 100%;
  overflow: hidden;
}
.xialabox{
  width: 100rpx;
  position: relative;
  float: left;
  height: 72rpx;
}
.xiala{
  width: 18rpx;
  height: 18rpx;
  border-right:2rpx solid #8a8a8a;
  border-top:2rpx solid #8a8a8a;
  transform: rotate(135deg);
  -webkit-transform: rotate(135deg);
  position: relative;
  top: 28rpx;
  transition: .6s all;
  -webkit-transition: .6s all;
  transform-origin: 11rpx 8rpx;
  left: 40rpx;
}
.xiala.active{
  transform: rotate(-45deg);
  -webkit-transform: rotate(-45deg);
  top: 32rpx;
}
.zhe{
  position: fixed;
  z-index: 5;
  top: 0;
  left: 0;
  height: 100%;
  width: 100%;
  background: rgba(255,255,255,.3);
}
.xialafixed{
  position: fixed;
  top: 74rpx;
  left: 0;
  width: 100%;
  min-height: 90rpx;
  background: #fff;
  z-index: 10;
  border-top: 2rpx solid #dfdfdf;
  padding: 18rpx 14rpx;
  overflow: hidden;
}
.xialafixed view{
  float: left;
  height: 66rpx;
  width: 144rpx;
  line-height: 66rpx;
  text-align: center;
  background: #f8f8f8;
  color: #000;
  margin: 12rpx 18rpx;
  border-radius: 66rpx;
  font-size: 28rpx;
}
image{
  display: block;
}
.swiperbox{
  height: 270rpx;
}
.swiperbox image{
  width: 100%;
  height: 270rpx;
}
.swiperbox .wx-swiper-dot{
    width:60rpx;  
    display: inline-flex;
    height: 4rpx;
    margin-left: 4rpx;
    justify-content:space-between;
}
.swiperbox .wx-swiper-dot::before{
    content: '';
    flex-grow: 1; 
    background: rgba(0,0,0,0.2);
}
.swiperbox .wx-swiper-dot-active::before{
    background:rgba(255,255,255,0.9); 
}
/* item-one  */
.item-one{
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-top:28rpx; 
}
.item-one .io-box{
  padding-bottom:28rpx; 
  overflow: hidden;
  border-bottom: 2rpx solid #f6f6f6;
}
.item-one .io-image{
  width: 194rpx;
  height: 194rpx;
  display: block;
}
.io-box navigator{
  float: left;
}
.item-one .io-right{
  float: left;
  margin-left: 26rpx;
  width: 470rpx;
  text-align: left;
  overflow: hidden;
  height: 194rpx;
  position: relative;
} 
.item-one .io-right .io-time{
  position: absolute;
  bottom: 0;
  left: 0;
  line-height: 34rpx;
  height: 34rpx;
  font-size: 24rpx;
  color: #7e7e7e;
}
.item-one .io-right .io-title{
  line-height: 50rpx;
  height: 150rpx;
  font-size: 32rpx;
  display: -webkit-box;
  color:#000000;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp:3;
  overflow: hidden;
  text-overflow:ellipsis;
}


