/* pages/openvip/openvip.wxss */
.br{
  height: 18rpx;
  width: 100%;
  background: #f8f8f8;
}
page{
  background: #f8f8f8;
}
.linebox{
  border-top:1rpx solid #f1f1f1;
  border-bottom: 1rpx solid #f6f6f6;
  width:100%;
  height: 0rpx;
  position: relative;
}
.rightvip{
  position: relative;
  height: 44rpx;
  border: 1rpx solid #ebebeb;
  line-height: 44rpx;
  color:#000;
  font-size: 22rpx;
  border-radius: 44rpx;
  padding-left:53rpx;
  padding-right:20rpx;

}
.rvicon{
  height: 26rpx;
  width: 32rpx;
  position: absolute;
  top: 11rpx;left: 14rpx;
}
.box{
  overflow: hidden;
  padding: 30rpx 24rpx;
  background: #fff;
}
.logo{
  float: left;
}
.logo image{
  height: 91rpx;
  width: 91rpx;
  display: block;
  border-radius: 91rpx;
}
.msg{
  float: left;
  margin-left: 20rpx;
}
.msg .name{
  font-size: 28rpx;
  line-height: 34rpx;
  height: 34rpx;
  margin-bottom: 12rpx;
}
.mainbox{
  padding: 0 24rpx;
  background: #fff;
}
.title{
  line-height: 72rpx;
  font-size: 24rpx;
}
.mainbox .tright{
  float: right;
}
.mainbox .tright icon{
  position: relative;
  top: 5rpx;
  left: -8rpx;
}
.types{
  padding-top: 32rpx;
  padding-bottom: 9rpx;
  display: flex;
  display: -webkit-flex;
  justify-content: space-between;
  width: 100%;
  flex-wrap: wrap;
}
.types .tone{
  width: 335rpx;
  height: 177rpx;
  border-radius: 6rpx;
  border: 2rpx solid #f2f2f2;
  display: inline-block; 
  text-align: center;
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
}
.types .tone.active{
  border: 2rpx solid #e83f39;
}
.types .tone.active .price{
  color: #e83f39;
}
.types .time{
  font-size: 20rpx;
  color: #797979;
  line-height: 20rpx;
}
.types .price{
  line-height: 36rpx;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  color: #111;
}
.types .tleft{
  width: 270rpx;
  float: left;
  padding-top: 50rpx;
}
.types .tright{
  width:30rpx;
  padding: 0 15rpx;
  float: right;
  background: #f2f2f2;
  height: 100%;
  font-size: 24rpx;
  padding-top: 64rpx;
  line-height: 24rpx;
}

.paybox{
  padding: 0 24rpx;
  padding-bottom: 30rpx;
  background: #fff;
}
.tip::after{
  content: "推荐";
  height: 30rpx;
  width: 60rpx;
  background: #e94a44;
  color: #fff;
  line-height: 30rpx;
  text-align: center;
  font-size: 22rpx;
  position: absolute;
  left: 0;
  top: 0;
}
.ptype image{
  width: 57rpx;
  height: 57rpx;
  display: block;
  float: left;
}
.ptype{
  padding-top: 26rpx;
  padding-bottom: 26rpx;
  overflow: hidden;
}
.ptr{
  float: left;
  padding-left: 20rpx;
}
.ptrtitle{
  font-size: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
}
.ptrcon{
  font-size: 22rpx;
  height: 22rpx;
  line-height: 22rpx;
  margin-top: 9rpx;
  color: #a2a2a2;

}
.ck{
  float: right;
}
/* checkbox未选中时样式 */
.ck checkbox .wx-checkbox-input{
  border-radius: 40rpx;
  height: 40rpx;
  width: 40rpx;
}
/* 选中后的 背景样式 （红色背景 无边框 可根据UI需求自己修改） */
checkbox .wx-checkbox-input.wx-checkbox-input-checked{
   border: 1rpx solid #e94a44;
   background-color: #e94a44;
}
/* 选中后的 对勾样式 （白色对勾 可根据UI需求自己修改） */
.ck checkbox .wx-checkbox-input.wx-checkbox-input-checked::before{
   border-radius: 50%;/* 圆角 */
   width: 20rpx;/* 选中后对勾大小，不要超过背景的尺寸 */
   height: 20rpx;/* 选中后对勾大小，不要超过背景的尺寸 */
   line-height: 20rpx;
   text-align: center;
   font-size:0rpx; /* 对勾大小 30rpx */
   color:#fff; /* 对勾颜色 白色 */
   background: #fff;
   transform:translate(-50%, -50%) scale(1);
   -webkit-transform:translate(-50%, -50%) scale(1);
}








/* 遮罩层 */
.goods-detail .mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 999999;
}
.goods-detail .mask {
  background: rgba(0, 0, 0, 0.7);
}
.goodsdetail {
  position: fixed;
  top: 120rpx;
  width: 620rpx;
  height: 850rpx;
  left: 65rpx;
  background: #fff;
  z-index: 1111111;
  border-radius: 10px;
  overflow: hidden;
}

/* 顶部提示信息 */
.dialogtip {
  margin-left: 50rpx;
  text-align: center;
  line-height: 88rpx;
  background-color: #e94a44;
  height: 88rpx;
  width: 520rpx;
  position: absolute;
  bottom: 40rpx;
  font-size: 30rpx;
  color: #fff;
}
.himg{
  width: 310rpx;
  height: 260rpx;
  display: inline-block;
  padding-top: 30rpx;
  padding-bottom: 10rpx;
}
.server{
  font-size: 26rpx;
  line-height: 44rpx;
  padding-left: 80rpx;
  position: relative;
  width: 512rpx;
  word-break: break-all;
}
.server::after{
  height: 4rpx;
  width: 4rpx;
  display: block;
  border-radius: 50%;
  background: #e95453;
  content: "";
  position: absolute;
  left: 60rpx;
  top: 20rpx;
}
