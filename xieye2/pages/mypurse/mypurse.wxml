<!--pages/mypurse/mypurse.wxml-->
<!-- 我的钱包  -->
<view class='box'>
  <image src='../../img/purse1.png'></image>
  <view class='v1'>我的余额</view>
  <view class="v2">￥998.00</view>
</view>
<view style='text-align:center;'>
  <view class='btn1' bindtap='refill'>充值</view>
  <view class='btn2' bindtap='withdrawcash'>提现</view>
  <view class='bill' bindtap='bill'>我的账单</view>
</view>