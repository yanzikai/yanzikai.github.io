<!--pages/changeloginpwd/changeloginpwd.wxml-->
<!-- 重置登录密码  -->
<view hidden='{{checked}}'>
  <view class='phone bb'>
    <input type='text' placeholder='请输入注册手机号'></input>
  </view>
  <view class='code bb'>
    <input type='number' placeholder='请输入验证码'></input>
    <view>获取验证码</view>
  </view>
  <view class='btnbox' bindtap='next'>
    <button class='btn'>下一步</button>
  </view>
</view>
<view hidden='{{!checked}}'>
  <view class='newpwd bb pwd'>
    <input type='text'  placeholder='请输入新密码'></input>
    <view><image src='../../img/eye1.png'></image></view>
  </view>
  <view class='rpwd bb pwd' >
    <input type='text'  placeholder='请再次输入密码'></input>
    <view><image src='../../img/eye2.png'></image></view>
  </view>
  <view class='btnbox'>
    <button class='btn'>完成</button>
  </view>
</view>